# Шаблон переменных окружения. Реальные значения НЕ коммитим.
# На сервере лежат в /var/www/af-sport/env.prod (см. deploy.sh: source этого файла).
# Локально: скопируй этот файл в .env и заполни.

# Supabase (self-hosted, api.af-sport.ru)
SUPABASE_URL="https://api.af-sport.ru"
VITE_SUPABASE_URL="https://api.af-sport.ru"
SUPABASE_PUBLISHABLE_KEY="<JWT role=anon>"
VITE_SUPABASE_PUBLISHABLE_KEY="<тот же anon>"
SUPABASE_SERVICE_ROLE_KEY="<JWT role=service_role — секрет, не в git!>"
VITE_SUPABASE_PROJECT_ID="af-selfhosted"

# Яндекс.Геокодер
YANDEX_GEOCODER_KEY="<ключ>"

# UUID администраторов через запятую
ADMIN_USER_IDS="<uuid>"

# PayKeeper (без VITE_ — только сервер)
PAYKEEPER_URL="https://af-sport.server.paykeeper.ru"
PAYKEEPER_SECRET="<секретное слово из кабинета PayKeeper — не в git!>"

# Telegram Mini App (без VITE_ — только сервер): токен бота от @BotFather
TELEGRAM_BOT_TOKEN="<токен бота — не в git!>"
