{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "comment": "Vercel больше не используется — переехали на self-hosted VPS reg.ru. Файл оставлен пустым на случай возврата.",
  "headers": [
    {
      "source": "/(sw.js|manifest.webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
